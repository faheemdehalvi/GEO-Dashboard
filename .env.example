# ─────────────────────────────────────────────────────────────
# Kynection GEO Dashboard — environment variables
# Copy to `.env` and fill in. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Supabase (persistence) ──────────────────────────────────
# If both are set, AEO + content items persist to Supabase.
# If unset, the dashboard falls back to local JSON files.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google (GA4 + Search Console) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GA4_PROPERTY_ID=386242225

# ── YouTube Analytics (uses Kynection channel-owner account) ─
YOUTUBE_REFRESH_TOKEN=

# ── SEMrush ─────────────────────────────────────────────────
SEMRUSH_API_KEY=
SEMRUSH_DOMAIN=kynection.com.au
SEMRUSH_DATABASE=au

# ── HubSpot ─────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=

# ── AI providers (AEO + Snipe) ──────────────────────────────
# OpenRouter (preferred for Snipe + Revamp — one bill, one usage dashboard).
# Used by callSnipeAI() first if set. AEO data-stream still uses direct
# provider keys below (citation/grounding parsing is provider-native and
# does not survive OpenRouter normalisation).
OPENROUTER_API_KEY=
OPENROUTER_MODEL_FAST=anthropic/claude-haiku-4.5
OPENROUTER_MODEL_FULL=anthropic/claude-sonnet-4.5
OPENROUTER_REFERER=https://geo-dashboard.local

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
DATAFORSEO_TOKEN=

# ── PageSpeed Insights (optional — has free quota without a key) ─
PSI_KEY=

# ── Server ──────────────────────────────────────────────────
PORT=4016
